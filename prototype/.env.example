# Copy this file to .env and fill in the values.
# Never commit .env — it is listed in .gitignore.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Supabase project credentials — https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=