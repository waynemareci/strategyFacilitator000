{
  "version": 2,
  "builds": [
    {
      "src": "prototype/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "prototype/index.html",
          "prototype/admin.html",
          "prototype/sw.js",
          "prototype/public/manifest.json",
          "prototype/public/icons/**",
          "prompts/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/manifest.json", "dest": "prototype/public/manifest.json" },
    { "src": "/sw.js", "dest": "prototype/server.js" },
    { "src": "/icons/(.*)", "dest": "prototype/public/icons/$1" },
    { "src": "/(.*)", "dest": "prototype/server.js" }
  ]
}
